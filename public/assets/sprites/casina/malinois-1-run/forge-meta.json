{
  "pipeline": "generate2dsprite",
  "target": "player",
  "mode": "player_sheet",
  "prompt": "Belgian Malinois guard dog, top-down RPG, 4-direction walk (down/left/right/up)",
  "rows": 4,
  "cols": 4,
  "cell_size": 128,
  "align": "feet",
  "shared_scale": true,
  "layout": {
    "down": "frames 0-3",
    "left": "frames 4-7",
    "right": "frames 8-11",
    "up": "frames 12-15"
  },
  "outputs": ["sheet-transparent.png", "player_sheet-1..16.png", "animation.gif"]
}
